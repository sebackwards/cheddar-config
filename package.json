{
  "name": "cheddar-config",
  "version": "1.0.0",
  "description": "User and workspace configuration management service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test":  "jest --runInBand --env=node --verbose"
  },
  "dependencies": {
    "express": "4.18.2",
    "uuid": "9.0.0",
    "module-alias":"2.2.3"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.11.5",
    "@types/uuid": "9.0.7",
    "supertest": "6.3.4",
    "typescript": "5.3.3",
    "jest": "29.7.0"
  },
  "_moduleAliases": {
    "cheddar-config": "dist"
  },
  "jest": {
  "moduleNameMapper": {
    "^cheddar-config/(.*)$": "<rootDir>/dist/$1",
    "^cheddar-config$": "<rootDir>/dist/index.js"
  }
}
}